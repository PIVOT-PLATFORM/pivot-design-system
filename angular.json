{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "design-system": {
      "projectType": "library",
      "root": ".",
      "sourceRoot": "src",
      "prefix": "pivot-ds",
      "architect": {
        "storybook": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/storybook-build",
            "index": ".storybook/index.html",
            "main": ".storybook/storybook-entry.ts",
            "tsConfig": ".storybook/tsconfig.json",
            "styles": ["src/scss/reset.scss", "src/scss/tokens.scss"]
          }
        },
        "storybook-build": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "browserTarget": "design-system:storybook",
            "configDir": ".storybook",
            "outputDir": "storybook-static",
            "compodoc": false
          }
        },
        "storybook-dev": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "browserTarget": "design-system:storybook",
            "configDir": ".storybook",
            "compodoc": false,
            "port": 6006
          }
        }
      }
    }
  }
}
