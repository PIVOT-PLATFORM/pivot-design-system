@pivot-platform:registry=https://npm.pkg.github.com

# Storybook 10 (@storybook/angular) déclare encore des plages de peers obsolètes :
#   - typescript "^4.9 || ^5" alors qu'Angular 22 (déjà présent) EXIGE TypeScript 6 ;
#   - @angular/* ">=18 < 23" en peerOptional, en conflit avec le pin exact 22.0.6.
# Ces conflits sont purement nominaux (les versions installées sont mutuellement
# compatibles — c'est Angular 22 qui impose TS 6). On aligne donc `npm install` et le
# `npm ci` de la CI sur la même résolution tolérante. À retirer quand Storybook élargit
# ses plages de peers à Angular 22 / TS 6.
legacy-peer-deps=true
